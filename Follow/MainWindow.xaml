<Window x:Class="Follow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Follow"
        Title="Ratten-Labor 0.3" Height="650" Width="850" Icon="/Ratte.png" BorderBrush="Red" WindowStyle="ThreeDBorderWindow">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <LinearGradientBrush.RelativeTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                        <RotateTransform Angle="-96.116" CenterX="0.5" CenterY="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </LinearGradientBrush.RelativeTransform>
                <GradientStop Color="#FFFF009D" Offset="1"/>
                <GradientStop Color="#FF672887"/>
                <GradientStop Color="#FFA900FF"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Button-Leiste -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="3,3,3,3">
            <Button Content="Grün" 
                    Click="Click_Gruen"
                    Width="80" Height="40" Margin="5" Background="#FF4EFF00" Cursor="Hand" FontWeight="Bold" FontSize="16" Foreground="#FF008D18"/>
            <Button Content="Rot" 
                    Click="Click_Rot"
                    Width="80" Height="40" Margin="5" Background="#FFFF4F4F" Cursor="Hand" FontWeight="Bold" FontSize="16" Foreground="#FFA10000"/>
            <Button Content="Blau" 
                    Click="Click_Blau"
                    Width="80" Height="40" Margin="5" Background="#FF0075FF" Cursor="Hand" FontWeight="Bold" FontSize="16" Foreground="#FF000A9E"/>
            <Button Content="Gelb" 
                    Click="Click_Gelb"
                    Width="80" Height="40" Margin="5" Background="#FFFBFF00" Cursor="Hand" FontWeight="Bold" FontSize="16" Foreground="#FFB1A000"/>
            <local:DraggableNumericKnob x:Name="LinkeZahl" Value="10.0" Step="0.01"/>
            <Border BorderBrush="Black" BorderThickness="0" Width="5"/>
            <local:DraggableNumericKnob x:Name="RechteZahl" Value="10.0" Step="0.01"/>
            <Border BorderBrush="Black" BorderThickness="0" Width="5"/>
            <Button Content="?" FontSize="20" Width="19" Height="30" Click="Button_Click" Background="#FFE900FF" Foreground="#FFD70000" FontWeight="Bold"/>
            
        </StackPanel><Label Content="Wissen oder Ratten?" Foreground="#FFFF51E2" FontSize="28" FontStyle="Italic" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontWeight="Bold"/>


        <!-- Zeichenfläche - WICHTIG: Der Name MUSS mit dem Code übereinstimmen! -->
        <Canvas x:Name="MainCanvas" 
                Grid.Row="1" 
                Background="White"/>
    </Grid>
</Window>